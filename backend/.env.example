# ---------------------------------------------
#  Example Environment Variables File
#  Rename this file to ".env" and fill in values
# ---------------------------------------------

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# Replace <username>, <password>, and <dbname> with actual credentials
MONGO_URI=mongodb+srv://civiclens_app:<db_password>@civiclens.wlcsfjr.mongodb.net/vitalbridge?retryWrites=true&w=majority&appName=CivicLens
# ---------------------------------------------
# Authentication
# ---------------------------------------------
# Use a long random string (at least 32 characters)
JWT_SECRET=your_jwt_secret_key_here

# ---------------------------------------------
# Server Configuration
# ---------------------------------------------
PORT=5000